<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- APP TITLE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌱 Hasiru-Usiru"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#1B5E20"
            android:layout_marginBottom="20dp"/>

        <!-- INPUT SECTION -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <!-- TREE NAME -->

            <EditText
                android:id="@+id/etSpecies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Tree Name"
                android:textSize="16sp"/>

            <!-- GIRTH -->

            <EditText
                android:id="@+id/etGirth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Tree Girth"
                android:inputType="number"
                android:textSize="16sp"
                android:layout_marginTop="12dp"/>

            <!-- ADD TREE BUTTON -->

            <Button
                android:id="@+id/btnAddTree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Tree 🌳"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#43A047"
                android:textColor="#FFFFFF"/>

            <!-- EMPTY PIT BUTTON -->

            <Button
                android:id="@+id/btnEmptyPit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mark Empty Pit ❌"
                android:textSize="18sp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#E53935"
                android:textColor="#FFFFFF"/>

            <!-- OPEN MAP BUTTON -->

            <Button
                android:id="@+id/btnOpenMap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Tree Map 🗺"
                android:textSize="18sp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#1E88E5"
                android:textColor="#FFFFFF"/>

            <!-- AI SUGGESTION -->

            <TextView
                android:id="@+id/tvSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 AI Suggestion will appear here"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="20dp"/>

        </LinearLayout>

        <!-- DASHBOARD SECTION -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#DCEDC8"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊 Dashboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <!-- TOTAL TREES -->

            <TextView
                android:id="@+id/tvTotalTrees"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌳 Total Trees: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <!-- TOTAL OXYGEN -->

            <TextView
                android:id="@+id/tvTotalOxygen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌱 Total Oxygen: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <!-- GREEN GAP -->

            <TextView
                android:id="@+id/tvGreenGap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌍 Green Gap Status"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- TREE LIST TITLE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌳 Trees List"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginTop="20dp"/>

        <!-- TREE LIST -->

        <ListView
            android:id="@+id/listViewTrees"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"/>

    </LinearLayout>

</ScrollView>